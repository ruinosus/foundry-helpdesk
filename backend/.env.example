# Copy to .env and fill in after provisioning Foundry (azd up).
# Auth is via DefaultAzureCredential — run `az login` / `azd auth login`, no keys here.

# Foundry project endpoint, e.g. https://<project>.services.ai.azure.com
FOUNDRY_PROJECT_ENDPOINT=

# Model deployment name
FOUNDRY_MODEL=gpt-4.1-mini

# Local frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:3000
