# Copy to .env and fill from `azd env get-values` after `azd up`.
# Auth is via DefaultAzureCredential — run `az login` / `azd auth login`, no keys here.

# --- Foundry (Phase 0) ---
# Foundry project endpoint, e.g. https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=gpt-5-mini

# --- Foundry IQ knowledge base (Phase 1) ---
# Foundry account OpenAI endpoint, e.g. https://<account>.openai.azure.com
AZURE_AI_OPENAI_ENDPOINT=
FOUNDRY_EMBEDDING_MODEL=text-embedding-3-small

# Azure AI Search (the knowledge base lives here)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KNOWLEDGE_BASE=helpdesk-kb

# Storage holding the corpus (used by the ingestion script)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_RESOURCE_ID=
AZURE_STORAGE_CONTAINER=corpus

# --- Entra ID + On-Behalf-Of (Phase 3) ---
# Leave blank to run without auth (DefaultAzureCredential fallback).
# Backend API app registration (audience of incoming tokens) + its client secret.
ENTRA_TENANT_ID=
ENTRA_API_CLIENT_ID=
ENTRA_API_CLIENT_SECRET=
# Frontend SPA app registration (for reference; the frontend uses it).
ENTRA_SPA_CLIENT_ID=

# --- Foundry memory store (Phase 3) ---
FOUNDRY_MEMORY_STORE=helpdesk-memory

# Local frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:3000
